# =============================================================================
# DnDPlanner — Variables de entorno para `docker compose`.
#
# Cópialo como `.env` (NO versionado) y rellena los valores.
#
#   cp .env.example .env
#
# Para generar los secretos JWT en PowerShell:
#   [Convert]::ToHexString((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
# =============================================================================

# ---- Autenticación (OBLIGATORIO) -------------------------------------------
# Cadenas aleatorias de al menos 32 bytes. NO usar las de ejemplo en producción.
JWT_SECRET=cambia-esto-por-32-bytes-aleatorios-en-hex
JWT_REFRESH_SECRET=cambia-esto-tambien-por-32-bytes-aleatorios-en-hex

# ---- Cloudinary (OPCIONAL) -------------------------------------------------
# Solo necesario si quieres habilitar la subida de imágenes a Cloudinary.
# Si lo dejas vacío, los endpoints /api/upload responderán 500 pero el resto
# de la API funciona sin problema.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
