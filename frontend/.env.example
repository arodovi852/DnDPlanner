# Frontend environment variables (Vite).
#
# Copy this file to `.env` for local development. In production these are
# injected by App Platform / Vercel / Netlify at build time.

# Base URL of the backend REST API (no trailing slash).
# Local dev:    http://localhost:3000/api
# Production:   https://api.yourdomain.me/api
VITE_API_URL=http://localhost:3000/api
